<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                    android:angle="135"
                    android:startColor="#2D1D2A"
                    android:centerColor="#26324C"
                    android:endColor="#1E3A3A"
                    android:type="linear"/>
        </shape>
    </item>
    <item android:gravity="top|end">
        <bitmap
                android:alpha="0.25"
                android:gravity="top|end"
                android:src="@drawable/asset_oga_sakura_tree"/>
    </item>
    <item>
        <bitmap
                android:alpha="0.10"
                android:gravity="center"
                android:src="@drawable/asset_oga_rain_overlay"/>
    </item>
</layer-list>
