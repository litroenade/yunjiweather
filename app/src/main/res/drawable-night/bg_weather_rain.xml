            <gradient
                    android:angle="270"
                    android:startColor="#1E3A5F"
                    android:centerColor="#10233E"
                    android:endColor="#050B14"/>
        </shape>
    </item>
    <item android:gravity="top|end" android:right="44dp" android:top="98dp">
