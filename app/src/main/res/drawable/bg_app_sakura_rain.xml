<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#F5F1E8"/>
        </shape>
    </item>
    <item android:gravity="top|end">
        <bitmap
                android:alpha="0.50"
                android:gravity="top|end"
