<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
                                                  xmlns:app="http://schemas.android.com/apk/res-auto"
                                                  xmlns:tools="http://schemas.android.com/tools"
                                                  android:layout_width="104dp"
                                                  android:layout_height="148dp"
                                                  android:layout_marginEnd="10dp"
                                                  android:clickable="true"
                                                  android:focusable="true"
                                                  android:foreground="?attr/selectableItemBackground"
                                                  app:cardBackgroundColor="@color/weather_surface"
                                                  app:cardCornerRadius="10dp"
                                                  app:cardElevation="0dp"
                                                  app:strokeColor="@color/weather_stroke"
                                                  app:strokeWidth="1dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingTop="11dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp">

        <TextView
                android:id="@+id/calendar_label_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/weather_text_secondary"
                android:textSize="12sp"
                tools:text="今天"/>

        <TextView
                android:id="@+id/calendar_day_text"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_chip_soft"
                android:gravity="center"
                android:textColor="@color/weather_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="21"/>

        <TextView
                android:id="@+id/calendar_weekday_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/weather_text_secondary"
                android:textSize="11sp"
                tools:text="星期四"/>

        <TextView
                android:id="@+id/calendar_lunar_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/weather_text_secondary"
                android:textSize="11sp"
                tools:text="四月初五"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="5dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

            <ImageView
                    android:id="@+id/calendar_icon_image"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:importantForAccessibility="no"
                    tools:src="@drawable/ic_weather_sunny"/>

            <TextView
                    android:id="@+id/calendar_temp_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:textColor="@color/weather_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="20°/30°"/>
        </LinearLayout>

        <TextView
                android:id="@+id/calendar_condition_text"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                tools:text="晴"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
