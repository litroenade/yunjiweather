<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="78dp"
              android:layout_height="108dp"
              android:layout_marginEnd="8dp"
              android:background="@drawable/bg_lunar_day_normal"
              android:clickable="true"
              android:focusable="true"
              android:foreground="?attr/selectableItemBackground"
              android:gravity="center"
              android:orientation="vertical"
              android:paddingStart="8dp"
              android:paddingTop="11dp"
              android:paddingEnd="8dp"
              android:paddingBottom="11dp">

    <TextView
            android:id="@+id/lunar_weekday_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/weather_text_secondary"
            android:textSize="12sp"
            tools:text="Preview"/>

    <TextView
            android:id="@+id/lunar_day_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:gravity="center"
            android:textColor="@color/weather_text_primary"
            android:textSize="23sp"
            android:textStyle="bold"
            tools:text="Preview"/>

    <TextView
            android:id="@+id/lunar_date_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/weather_text_secondary"
            android:textSize="12sp"
            tools:text="Preview"/>

    <TextView
            android:id="@+id/lunar_festival_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/weather_primary"
            android:textSize="11sp"
            tools:text="Preview"/>
</LinearLayout>
