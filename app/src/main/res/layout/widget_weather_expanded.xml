<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_weather_background"
    android:clipToOutline="true">

    <ImageView
        android:id="@+id/widget_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.58"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/theme_panorama_day"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_weather_overlay"/>

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:alpha="0.92"
        android:contentDescription="@null"
        android:src="@drawable/ic_weather_sunny"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.85"
            android:orientation="vertical">

            <TextView
                style="@style/WidgetWeatherText"
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/app_name"
                android:textColor="#FFFFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <TextView
                style="@style/WidgetWeatherText"
                android:id="@+id/widget_temperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/widget_weather_temperature_placeholder"
                android:textColor="#FFFFFFFF"
                android:textSize="48sp"/>

            <TextView
                style="@style/WidgetWeatherText"
                android:id="@+id/widget_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text=""
                android:textColor="#E6FFFFFF"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.35"
            android:gravity="end|center_vertical"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <TextView
                style="@style/WidgetWeatherText"
                android:id="@+id/widget_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="end"
                android:maxLines="1"
                android:text="@string/widget_weather_summary_placeholder"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                style="@style/WidgetWeatherText"
                android:id="@+id/widget_update_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="end"
                android:maxLines="1"
                android:text=""
                android:textColor="#E6FFFFFF"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="end"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:id="@+id/widget_life_clothing_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="短袖"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="穿衣"
                        android:textColor="#CCFFFFFF"
                        android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:id="@+id/widget_life_fishing_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="适宜"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="钓鱼"
                        android:textColor="#CCFFFFFF"
                        android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:id="@+id/widget_life_sunset_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="一般"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="晚霞"
                        android:textColor="#CCFFFFFF"
                        android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:id="@+id/widget_life_cold_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="不易"
                        android:textColor="#FFFFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        style="@style/WidgetWeatherText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="感冒"
                        android:textColor="#CCFFFFFF"
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/WidgetWeatherText"
                android:id="@+id/widget_advice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:gravity="end"
                android:maxLines="1"
                android:text=""
                android:textColor="#D9FFFFFF"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
