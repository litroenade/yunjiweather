<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            xmlns:tools="http://schemas.android.com/tools"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_auth_weather"
            android:clipToPadding="false"
            android:fillViewport="true"
            tools:context=".ui.auth.AuthActivity">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="680dp"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="36dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

        <ImageView
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:background="@drawable/bg_auth_icon"
                android:contentDescription="@string/app_name"
                android:padding="18dp"
                android:src="@drawable/ic_weather_sunny"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="@string/app_name"
                android:textColor="@color/auth_hero_title"
                android:textSize="32sp"
                android:textStyle="bold"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/auth_subtitle"
                android:textColor="@color/auth_hero_subtitle"
                android:textSize="15sp"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_auth_chip"
                android:gravity="center"
                android:minWidth="178dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/auth_badge_local_account"
                android:textColor="@color/auth_chip_text"
                android:textSize="13sp"/>

        <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@color/auth_card_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/auth_card_stroke"
                app:strokeWidth="1dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                <TextView
                        android:id="@+id/mode_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auth_login_title"
                        android:textColor="@color/weather_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                <TextView
                        android:id="@+id/mode_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/auth_login_subtitle"
                        android:textColor="@color/weather_text_secondary"
                        android:textSize="14sp"/>

                <TextView
                        android:id="@+id/auth_helper_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_auth_chip"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:text="@string/auth_login_helper"
                        android:textColor="@color/auth_chip_text"
                        android:textSize="13sp"/>

                <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/username_input_layout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:hint="@string/auth_username_hint"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:startIconTint="@color/weather_text_secondary"
                        app:startIconDrawable="@drawable/ic_mine_black_24dp">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/username_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionNext"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/weather_text_primary"
                            android:textColorHint="@color/weather_text_secondary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/display_name_input_layout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/auth_display_name_hint"
                        android:visibility="gone"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:startIconTint="@color/weather_text_secondary"
                        app:startIconDrawable="@drawable/ic_mine_black_24dp">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/display_name_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionNext"
                            android:inputType="textPersonName"
                            android:maxLines="1"
                            android:textColor="@color/weather_text_primary"
                            android:textColorHint="@color/weather_text_secondary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/password_input_layout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/auth_password_hint"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/weather_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/password_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/weather_text_primary"
                            android:textColorHint="@color/weather_text_secondary"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                        android:id="@+id/error_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/weather_error"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="用户名或密码错误"/>

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/submit_button"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="18dp"
                        android:text="@string/auth_login_button"
                        android:textSize="16sp"
                        app:cornerRadius="14dp"/>

                <com.google.android.material.button.MaterialButton
                        android:id="@+id/switch_mode_button"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/auth_switch_to_register"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
