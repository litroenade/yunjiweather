<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="82dp"
              android:layout_height="wrap_content"
              android:layout_marginEnd="12dp"
              android:background="@drawable/bg_chip_soft"
              android:gravity="center"
              android:orientation="vertical"
              android:paddingStart="6dp"
              android:paddingTop="8dp"
              android:paddingEnd="6dp"
              android:paddingBottom="8dp">

    <TextView
            android:id="@+id/hourly_time_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/weather_text_secondary"
            android:textSize="12sp"
            tools:text="14:00"/>

    <ImageView
            android:id="@+id/hourly_icon_image"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginTop="6dp"
            android:importantForAccessibility="no"
            tools:src="@drawable/ic_weather_cloudy"/>

    <TextView
            android:id="@+id/hourly_condition_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/weather_text_secondary"
            android:textSize="12sp"
            tools:text="多云"/>

    <TextView
            android:id="@+id/hourly_temp_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:textColor="@color/weather_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="24°"/>
</LinearLayout>
