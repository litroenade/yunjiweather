<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_weather_background"
    android:clipToOutline="true">

    <ImageView
        android:id="@+id/widget_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.58"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/theme_panorama_day"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_weather_overlay"/>

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:alpha="0.92"
        android:contentDescription="@null"
        android:src="@drawable/ic_weather_sunny"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <TextView
            style="@style/WidgetWeatherText"
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="#FFFFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

        <TextView
            style="@style/WidgetWeatherText"
            android:id="@+id/widget_temperature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_weather_temperature_placeholder"
            android:textColor="#FFFFFFFF"
            android:textSize="44sp"/>

        <TextView
            style="@style/WidgetWeatherText"
            android:id="@+id/widget_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="#E6FFFFFF"
            android:textSize="14sp"/>

        <TextView
            style="@style/WidgetWeatherText"
            android:id="@+id/widget_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_weather_summary_placeholder"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"/>

        <TextView
            style="@style/WidgetWeatherText"
            android:id="@+id/widget_update_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

    <TextView
        style="@style/WidgetWeatherText"
        android:id="@+id/widget_advice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"/>

</FrameLayout>
