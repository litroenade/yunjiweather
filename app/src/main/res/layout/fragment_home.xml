<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             xmlns:tools="http://schemas.android.com/tools"
             android:id="@+id/home_root"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:background="@drawable/bg_weather_sunny"
             tools:context=".ui.home.HomeFragment">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <ScrollView
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="28dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="28dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <TextView
                            android:id="@+id/city_name_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="Preview"/>

                    <com.google.android.material.button.MaterialButton
                            android:id="@+id/location_button"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:paddingStart="15dp"
                            android:paddingEnd="15dp"
                            android:text="@string/home_location"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            app:cornerRadius="2dp"
                            app:strokeColor="@android:color/white"/>

                    <com.google.android.material.button.MaterialButton
                            android:id="@+id/refresh_button"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:paddingStart="15dp"
                            android:paddingEnd="15dp"
                            android:text="@string/home_refresh"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            app:cornerRadius="2dp"
                            app:strokeColor="@android:color/white"/>
                </LinearLayout>

                <TextView
                        android:id="@+id/cache_state_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/weather_header_secondary"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="Preview"/>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="2dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/weather_stroke"
                        app:strokeWidth="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="20dp">

                        <ImageView
                                android:id="@+id/weather_icon_image"
                                android:layout_width="78dp"
                                android:layout_height="78dp"
                                android:contentDescription="@string/home_weather_icon"
                                tools:src="@drawable/ic_weather_sunny"/>

                        <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                            <TextView
                                    android:id="@+id/temp_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/weather_text_primary"
                                    android:textSize="54sp"
                                    android:textStyle="bold"
                                    tools:text="Preview"/>

                            <TextView
                                    android:id="@+id/condition_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/weather_text_primary"
                                    android:textSize="18sp"
                                    tools:text="Preview"/>

                            <TextView
                                    android:id="@+id/feels_like_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="Preview"/>

                            <TextView
                                    android:id="@+id/temp_range_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="Preview"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="2dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/weather_stroke"
                        app:strokeWidth="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_today_detail"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:orientation="horizontal">

                            <TextView
                                    android:id="@+id/humidity_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="Preview"/>

                            <TextView
                                    android:id="@+id/wind_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="Preview"/>
                        </LinearLayout>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                            <TextView
                                    android:id="@+id/pressure_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="Preview"/>

                            <TextView
                                    android:id="@+id/visibility_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="Preview"/>
                        </LinearLayout>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:background="@drawable/bg_chip_soft"
                                android:orientation="vertical"
                                android:paddingStart="14dp"
                                android:paddingTop="11dp"
                                android:paddingEnd="14dp"
                                android:paddingBottom="11dp">

                            <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_air_quality"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="13sp"/>

                            <TextView
                                    android:id="@+id/air_quality_text"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:textColor="@color/weather_text_primary"
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    tools:text="Preview"/>

                            <TextView
                                    android:id="@+id/air_primary_text"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="13sp"
                                    tools:text="Preview"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="2dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/weather_stroke"
                        app:strokeWidth="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_weather_calendar"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/home_weather_calendar_summary"
                                android:textColor="@color/weather_text_secondary"
                                android:textSize="13sp"/>

                        <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/weather_calendar_recycler_view"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:clipToPadding="false"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never"
                                android:paddingEnd="6dp"
                                android:scrollbars="none"
                                tools:listitem="@layout/item_weather_calendar_day"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="2dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/weather_stroke"
                        app:strokeWidth="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_hourly_weather"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/hourly_forecast_recycler_view"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:clipToPadding="false"
                                android:nestedScrollingEnabled="false"
                                android:overScrollMode="never"
                                android:paddingEnd="6dp"
                                android:scrollbars="none"
                                tools:listitem="@layout/item_home_hourly"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="2dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/weather_stroke"
                        app:strokeWidth="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_daily_forecast"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/daily_forecast_recycler_view"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:nestedScrollingEnabled="false"
                                tools:listitem="@layout/item_home_daily"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="2dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/weather_stroke"
                        app:strokeWidth="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/home_life_advice"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <TextView
                                android:id="@+id/clothing_advice_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/weather_text_secondary"
                                android:textSize="14sp"
                                tools:text="Preview"/>

                        <TextView
                                android:id="@+id/travel_advice_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="@color/weather_text_secondary"
                                android:textSize="14sp"
                                tools:text="Preview"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                        android:id="@+id/update_time_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:textColor="@color/weather_header_secondary"
                        android:textSize="13sp"
                        tools:text="Preview"/>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone"/>

    <LinearLayout
            android:id="@+id/error_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="24dp"
            android:background="@drawable/bg_card_soft"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

        <TextView
                android:id="@+id/error_title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_weather_load_failed"
                android:textColor="@color/weather_error"
                android:textSize="18sp"
                android:textStyle="bold"/>

        <TextView
                android:id="@+id/error_message_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/weather_text_secondary"
                android:textSize="14sp"
                tools:text="Preview"/>

        <com.google.android.material.button.MaterialButton
                android:id="@+id/retry_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/home_retry"/>
    </LinearLayout>
</FrameLayout>
