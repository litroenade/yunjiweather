<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             xmlns:tools="http://schemas.android.com/tools"
             android:id="@+id/home_root"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:background="@drawable/bg_weather_sunny"
             tools:context=".ui.home.HomeFragment">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <ScrollView
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingTop="28dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="28dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                    <TextView
                            android:id="@+id/city_name_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@android:color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="北京"/>

                    <com.google.android.material.button.MaterialButton
                            android:id="@+id/location_button"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginEnd="8dp"
                            android:text="定位"
                            android:textColor="@android:color/white"
                            app:strokeColor="@android:color/white"/>

                    <com.google.android.material.button.MaterialButton
                            android:id="@+id/refresh_button"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="刷新"
                            android:textColor="@android:color/white"
                            app:strokeColor="@android:color/white"/>
                </LinearLayout>

                <TextView
                        android:id="@+id/cache_state_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#E8F4FF"
                        android:textSize="13sp"
                        android:visibility="gone"
                        tools:text="网络连接失败，已显示本地缓存。"/>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="22dp">

                        <ImageView
                                android:id="@+id/weather_icon_image"
                                android:layout_width="86dp"
                                android:layout_height="86dp"
                                android:contentDescription="天气图标"
                                tools:src="@drawable/ic_weather_sunny"/>

                        <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="18dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                            <TextView
                                    android:id="@+id/temp_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/weather_text_primary"
                                    android:textSize="58sp"
                                    android:textStyle="bold"
                                    tools:text="24°"/>

                            <TextView
                                    android:id="@+id/condition_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/weather_text_primary"
                                    android:textSize="18sp"
                                    tools:text="多云"/>

                            <TextView
                                    android:id="@+id/feels_like_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="体感 26°"/>

                            <TextView
                                    android:id="@+id/temp_range_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="今日 20° / 30°"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="今日详情"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:orientation="horizontal">

                            <TextView
                                    android:id="@+id/humidity_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="湿度 72%"/>

                            <TextView
                                    android:id="@+id/wind_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="东南风 1级"/>
                        </LinearLayout>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                            <TextView
                                    android:id="@+id/pressure_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="气压 1003 hPa"/>

                            <TextView
                                    android:id="@+id/visibility_text"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:textColor="@color/weather_text_secondary"
                                    android:textSize="14sp"
                                    tools:text="能见度 16 km"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="空气质量"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <TextView
                                android:id="@+id/air_quality_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="AQI 55 · 良"/>

                        <TextView
                                android:id="@+id/air_primary_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/weather_text_secondary"
                                android:textSize="14sp"
                                tools:text="首要污染物：PM2.5"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="逐小时天气"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <HorizontalScrollView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:scrollbars="none">

                            <LinearLayout
                                    android:id="@+id/hourly_forecast_container"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"/>
                        </HorizontalScrollView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未来三天"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <LinearLayout
                                android:id="@+id/daily_forecast_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="vertical"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/weather_card"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="18dp">

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="生活建议"
                                android:textColor="@color/weather_text_primary"
                                android:textSize="17sp"
                                android:textStyle="bold"/>

                        <TextView
                                android:id="@+id/clothing_advice_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:textColor="@color/weather_text_secondary"
                                android:textSize="14sp"
                                tools:text="穿衣：建议穿短袖或薄外套。"/>

                        <TextView
                                android:id="@+id/travel_advice_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="@color/weather_text_secondary"
                                android:textSize="14sp"
                                tools:text="出行：天气适合出行。"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                        android:id="@+id/update_time_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:textColor="#E8F4FF"
                        android:textSize="13sp"
                        tools:text="更新时间：2026-05-17 22:20"/>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone"/>

    <LinearLayout
            android:id="@+id/error_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="24dp"
            android:background="@color/weather_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

        <TextView
                android:id="@+id/error_title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="天气加载失败"
                android:textColor="@color/weather_error"
                android:textSize="18sp"
                android:textStyle="bold"/>

        <TextView
                android:id="@+id/error_message_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/weather_text_secondary"
                android:textSize="14sp"
                tools:text="请检查 API Host、API Key 或网络连接。"/>

        <com.google.android.material.button.MaterialButton
                android:id="@+id/retry_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="重试"/>
    </LinearLayout>
</FrameLayout>
