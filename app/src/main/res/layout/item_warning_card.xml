<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
                                                  xmlns:app="http://schemas.android.com/apk/res-auto"
                                                  xmlns:tools="http://schemas.android.com/tools"
                                                  android:layout_width="match_parent"
                                                  android:layout_height="wrap_content"
                                                  android:layout_marginBottom="12dp"
                                                  app:cardBackgroundColor="@color/weather_surface"
                                                  app:cardCornerRadius="16dp"
                                                  app:cardElevation="0dp"
                                                  app:strokeColor="@color/weather_stroke"
                                                  app:strokeWidth="1dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

        <View
                android:id="@+id/warning_level_strip"
                android:layout_width="5dp"
                android:layout_height="match_parent"
                tools:background="#B42318"/>

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="18dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/warning_level_text"
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_warning_level_chip"
                        android:gravity="center"
                        android:minWidth="72dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="红色预警"/>

                <TextView
                        android:id="@+id/read_state_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:textColor="@color/weather_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="未读"/>
            </LinearLayout>

            <TextView
                    android:id="@+id/warning_title_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/weather_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="暴雨红色预警"/>

            <TextView
                    android:id="@+id/warning_meta_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="13sp"
                    tools:text="类型：暴雨"/>

            <TextView
                    android:id="@+id/warning_time_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/weather_text_secondary"
                    android:textSize="13sp"
                    tools:text="发布时间：2026-05-20 09:30"/>

            <TextView
                    android:id="@+id/warning_content_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/weather_text_secondary"
                    android:textSize="14sp"
                    tools:text="请注意防范强降雨带来的道路积水和出行风险。"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
