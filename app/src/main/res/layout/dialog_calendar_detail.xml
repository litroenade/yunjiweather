<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:background="@drawable/bg_calendar_sheet"
              android:orientation="vertical"
              android:paddingStart="22dp"
              android:paddingTop="12dp"
              android:paddingEnd="22dp"
              android:paddingBottom="24dp">

    <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_bottom_sheet_handle"/>

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

            <TextView
                    android:id="@+id/calendar_detail_month_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/weather_text_secondary"
                    android:textSize="14sp"
                    tools:text="Preview"/>

            <TextView
                    android:id="@+id/calendar_detail_day_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="@color/weather_text_primary"
                    android:textSize="58sp"
                    android:textStyle="bold"
                    tools:text="Preview"/>
        </LinearLayout>

        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

            <TextView
                    android:id="@+id/calendar_detail_title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_calendar_title_chip"
                    android:gravity="center"
                    android:minWidth="92dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/weather_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="Preview"/>

            <TextView
                    android:id="@+id/calendar_detail_weekday_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/weather_text_secondary"
                    android:textSize="15sp"
                    tools:text="Preview"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_calendar_lunar_band"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="15dp"
            android:paddingEnd="16dp"
            android:paddingBottom="15dp">

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
            android:text="@android:string/ok"
                    android:textColor="@color/weather_text_secondary"
                    android:textSize="12sp"/>

            <TextView
                    android:id="@+id/calendar_detail_lunar_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/weather_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Preview"/>
        </LinearLayout>

        <View
                android:layout_width="1dp"
                android:layout_height="42dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@color/weather_stroke"/>

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
            android:text="@android:string/ok"
                    android:textColor="@color/weather_text_secondary"
                    android:textSize="12sp"/>

            <TextView
                    android:id="@+id/calendar_detail_festival_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:textColor="@color/weather_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Preview"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
            android:id="@+id/calendar_detail_weather_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_calendar_weather_band"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
            android:text="@android:string/ok"
                android:textColor="@color/weather_text_secondary"
                android:textSize="13sp"/>

        <TextView
                android:id="@+id/calendar_detail_weather_condition_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/weather_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Preview"/>

        <TextView
                android:id="@+id/calendar_detail_weather_temp_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/weather_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Preview"/>
    </LinearLayout>

    <TextView
            android:id="@+id/calendar_detail_advice_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/weather_text_secondary"
            android:textSize="14sp"
            tools:text="Preview"/>

    <com.google.android.material.button.MaterialButton
            android:id="@+id/calendar_detail_close_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="@android:string/ok"
            android:textSize="15sp"
            app:cornerRadius="2dp"/>
</LinearLayout>
