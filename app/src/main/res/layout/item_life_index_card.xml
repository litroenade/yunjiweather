<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:minHeight="128dp"
              android:orientation="vertical">

    <TextView
            android:id="@+id/index_name_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/weather_text_primary"
            android:textSize="17sp"
            android:textStyle="bold"/>

    <TextView
            android:id="@+id/index_level_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/weather_primary"
            android:textSize="15sp"
            android:textStyle="bold"/>

    <TextView
            android:id="@+id/index_advice_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/weather_text_secondary"
            android:textSize="13sp"/>
</LinearLayout>
