<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
                                                  xmlns:app="http://schemas.android.com/apk/res-auto"
                                                  android:layout_width="match_parent"
                                                  android:layout_height="wrap_content"
                                                  android:layout_margin="6dp"
                                                  app:cardBackgroundColor="@color/weather_surface"
                                                  app:cardCornerRadius="16dp"
                                                  app:cardElevation="0dp"
                                                  app:strokeColor="@color/weather_stroke"
                                                  app:strokeWidth="1dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="136dp"
            android:orientation="vertical"
            android:padding="16dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:id="@+id/index_icon_text"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_index_icon"
                    android:gravity="center"
                    android:textColor="@color/weather_text_inverse"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            <TextView
                    android:id="@+id/index_name_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/weather_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"/>
        </LinearLayout>

        <TextView
                android:id="@+id/index_level_text"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_soft"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/weather_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>

        <TextView
                android:id="@+id/index_advice_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/weather_text_secondary"
                android:textSize="13sp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
